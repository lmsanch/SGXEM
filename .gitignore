__pycache__/
*.pyc

# Local downloaded source datasets. These can be large and may carry their own
# redistribution restrictions.
artifacts/*_source/
artifacts/flir_adas/

# Local selected media artifacts. Keep directory placeholders, but do not track
# copied audio/image/depth payloads from third-party datasets.
artifacts/audio/*
!artifacts/audio/.gitkeep
artifacts/depth/*
!artifacts/depth/.gitkeep
artifacts/thermal/*
!artifacts/thermal/.gitkeep

# Local curation/runtime outputs.
curation_log.jsonl
.env

# New underwater acoustic source directories
artifacts/shipsear_source/
artifacts/sanctsound_source/
artifacts/deepship_source/
artifacts/dclde_source/

# Defense benchmark (T1+): fetched Wikipedia/Wikidata corpus text (CC BY-SA,
# regenerable from the committed entity lists) and derived KMS records/runtime state.
data/defense_corpus/corpus/wiki_bridge/WIKI-*.txt
data/defense_corpus/kms_records/

# CRS raw prose (public domain; captured in sgxem_chunks.jsonl + crs_manifest.jsonl)
data/defense_corpus/corpus/crs/

# T5 raw compositions (regenerable; large)
data/t5_raw/
